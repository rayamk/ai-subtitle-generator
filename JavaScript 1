function generateSRT(text) {
  const sentences = text.split(". ");
  let srt = "";

  let start = 1;

  sentences.forEach((line, i) => {
    const end = start + 2;

    srt += `${i + 1}
00:00:${start.toString().padStart(2, "0")},000 --> 00:00:${end.toString().padStart(2, "0")},000
${line}

`;

    start += 3;
  });

  return srt;
}
